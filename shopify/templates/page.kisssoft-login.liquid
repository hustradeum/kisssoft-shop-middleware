{% layout none %}
{% comment %}
  KISSsoft Shop Login Gate
  Template: page.kisssoft-login
  Deploy: Shopify Admin → Online Store → Themes → Edit code → templates/page.kisssoft-login.liquid
  Create a page in Shopify with handle "login" and assign this template.
{% endcomment %}

{% assign middleware_url = 'https://kisssoft-middleware.tradeumcloud.ch' %}

<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page.title }} — {{ shop.name }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; border-radius: 0 !important; }

    html, body {
      height: 100%;
    }

    body {
      font-family: 'Roboto', Helvetica, Arial, sans-serif;
      background: #f4f4f5;
      min-height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .card {
      background: #fff;
      box-shadow: 0 4px 24px rgba(0,0,0,0.10);
      padding: clamp(20px, 5vw, 44px) clamp(18px, 5vw, 40px);
      width: 100%;
      max-width: 420px;
      margin: 0 auto;
    }

    .logo {
      display: flex;
      justify-content: center;
      margin-bottom: clamp(20px, 4vw, 28px);
    }

    .logo img {
      height: clamp(36px, 6vw, 48px);
      width: auto;
    }

    h1 {
      font-size: clamp(19px, 4vw, 24px);
      font-weight: 700;
      color: #111;
      margin-bottom: 5px;
      text-align: center;
    }

    .subtitle {
      font-size: clamp(13px, 2.5vw, 15px);
      color: #6b7280;
      text-align: center;
      margin-bottom: clamp(18px, 4vw, 28px);
      line-height: 1.5;
    }

    label {
      display: block;
      font-size: clamp(12px, 2.2vw, 14px);
      font-weight: 500;
      color: #374151;
      margin-bottom: 5px;
    }

    input[type="email"],
    input[type="password"] {
      display: block;
      width: 100%;
      padding: clamp(9px, 2vw, 11px) 14px;
      font-size: clamp(14px, 2.5vw, 16px);
      font-family: 'Roboto', Helvetica, Arial, sans-serif;
      border: 1.5px solid #d1d5db;
      outline: none;
      transition: border-color 0.15s;
      color: #111;
      background: #fff;
    }

    input:focus {
      border-color: #007AC2;
    }

    .field {
      margin-bottom: clamp(12px, 2.5vw, 16px);
    }

    .btn {
      display: block;
      width: 100%;
      padding: clamp(10px, 2.5vw, 13px);
      font-size: clamp(14px, 2.5vw, 16px);
      font-family: 'Roboto', Helvetica, Arial, sans-serif;
      font-weight: 700;
      color: #fff;
      background: #007AC2;
      border: none;
      cursor: pointer;
      margin-top: 6px;
      transition: background 0.15s, opacity 0.15s;
      letter-spacing: 0.02em;
    }

    .btn:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }

    .btn:hover:not(:disabled) {
      background: #005f99;
    }

    .error-box {
      display: none;
      background: #fef2f2;
      border-left: 4px solid #b91c1c;
      color: #b91c1c;
      padding: clamp(10px, 2vw, 12px) 14px;
      font-size: clamp(12px, 2.2vw, 14px);
      margin-top: 14px;
      line-height: 1.5;
    }

    .error-box.visible {
      display: flex;
      align-items: flex-start;
      gap: 10px;
    }

    .error-icon {
      flex-shrink: 0;
      font-size: 16px;
      line-height: 1.4;
    }

    .error-text { flex: 1; }

    .error-retry {
      display: inline-block;
      margin-top: 6px;
      font-size: clamp(11px, 2vw, 13px);
      color: #007AC2;
      cursor: pointer;
      text-decoration: underline;
      background: none;
      border: none;
      padding: 0;
      font-family: 'Roboto', Helvetica, Arial, sans-serif;
    }


    @media (max-width: 480px) {
      body { padding: 0 10%; }
      .card { padding-top: 10%; padding-bottom: 10%; }
    }

    @media (max-height: 600px) {
      .logo { margin-bottom: 12px; }
      .logo img { height: 30px; }
      .subtitle { margin-bottom: 12px; }
      .field { margin-bottom: 10px; }
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">
      {% if shop.logo %}
        <img src="{{ shop.logo | img_url: '200x' }}" alt="{{ shop.name }}">
      {% else %}
        <strong style="font-size:22px;color:#007AC2;">{{ shop.name }}</strong>
      {% endif %}
    </div>

    <h1>
      {% if request.locale.iso_code == 'de' %}
        Shop-Zugang
      {% else %}
        Shop Access
      {% endif %}
    </h1>
    <p class="subtitle">
      {% if request.locale.iso_code == 'de' %}
        Bitte melden Sie sich mit Ihrem MyKISSsoft-Konto an.
      {% else %}
        Please sign in with your MyKISSsoft account.
      {% endif %}
    </p>

    <form id="login-form" autocomplete="on" novalidate>
      <div class="field">
        <label for="email">
          {% if request.locale.iso_code == 'de' %}E-Mail-Adresse{% else %}Email address{% endif %}
        </label>
        <input type="email" id="email" name="email" autocomplete="email" required
          placeholder="name@company.com">
      </div>

      <div class="field">
        <label for="password">
          {% if request.locale.iso_code == 'de' %}Passwort{% else %}Password{% endif %}
        </label>
        <input type="password" id="password" name="password" autocomplete="current-password" required>
      </div>

      <button type="submit" class="btn" id="submit-btn">
        {% if request.locale.iso_code == 'de' %}Anmelden{% else %}Sign in{% endif %}
      </button>

      <div class="error-box" id="error-box" role="alert">
        <span class="error-icon">⚠</span>
        <div class="error-text">
          <span id="error-msg"></span>
        </div>
      </div>
    </form>

  </div>

  <script>
    const MIDDLEWARE_URL = '{{ middleware_url }}';
    const COOKIE_NAME = 'kiss_session';
    const COOKIE_MAX_AGE = 12 * 60 * 60;
    const IS_DE = '{{ request.locale.iso_code }}' === 'de';
    const LABEL_SUBMIT = IS_DE ? 'Anmelden' : 'Sign in';
    const LABEL_LOADING = IS_DE ? 'Wird überprüft …' : 'Verifying …';
    const MSG_INVALID = IS_DE
      ? '<strong>Zugang verweigert – MyKISSsoft-Login erforderlich</strong><br><br>Um auf den KISSsoft-Webshop zuzugreifen, ist ein gültiges MyKISSsoft-Konto erforderlich.<br><br>Falls Sie noch kein MyKISSsoft-Konto besitzen, registrieren Sie sich bitte zuerst, um Zugang anzufordern.<br><br>Sobald Ihr MyKISSsoft-Konto erstellt und aktiviert wurde, können Sie den Webshop betreten und seine Dienste nutzen.<br><br><strong>Brauchen Sie Hilfe?</strong><br>Bei Fragen zur Registrierung oder zum Konto-Zugang wenden Sie sich bitte an Ihren KISSsoft-Ansprechpartner.'
      : '<strong>Access Restricted – MyKISSsoft Login Required</strong><br><br>To access the KISSsoft webshop, a valid MyKISSsoft account is required.<br><br>If you do not have a MyKISSsoft account yet, please register first to request access.<br><br>Once your MyKISSsoft account has been created and activated, you will be able to enter the webshop and use its services.<br><br><strong>Need help?</strong><br>Please contact our KISSsoft contact partner if you have any questions regarding registration or account access.';
    const MSG_REGION = IS_DE
      ? '<strong>Zugang eingeschränkt - Service in Ihrer Region nicht verfügbar</strong><br><br>Der Zugang zu diesem Webshop ist aus Ihrem Land oder Ihrer Region derzeit nicht möglich.<br><br>Falls Sie glauben, dass diese Einschränkung fälschlicherweise angewendet wurde, wenden Sie sich bitte an Ihren KISSsoft-Ansprechpartner.<br><br><em>Wir danken für Ihr Verständnis.</em>'
      : '<strong>Access Restricted - Service Not Available in Your Region</strong><br><br>We regret to inform you that access to this webshop is currently not available from your country or region.<br><br>If you believe this restriction has been applied in error, please contact your KISSsoft contact partner for further assistance.<br><br><em>Thank you for your understanding.</em>';
    const MSG_NETWORK = IS_DE
      ? 'Verbindungsfehler - bitte Internetverbindung prüfen und erneut versuchen.'
      : 'Connection error - please check your internet connection and try again.';
    const MSG_SERVER = IS_DE
      ? 'Serverfehler - bitte später erneut versuchen.'
      : 'Server error - please try again later.';

    function setCookie(name, value, seconds) {
      const expires = new Date(Date.now() + seconds * 1000).toUTCString();
      document.cookie = `${name}=${encodeURIComponent(value)}; expires=${expires}; path=/; SameSite=Lax`;
    }

    const form = document.getElementById('login-form');
    const submitBtn = document.getElementById('submit-btn');
    const errorBox = document.getElementById('error-box');
    const errorMsg = document.getElementById('error-msg');

    function showError(msg) {
      errorMsg.innerHTML = msg;
      errorBox.classList.add('visible');
    }

    function hideError() {
      errorBox.classList.remove('visible');
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      hideError();
      submitBtn.disabled = true;
      submitBtn.textContent = LABEL_LOADING;

      const email = document.getElementById('email').value.trim();
      const password = document.getElementById('password').value;

      try {
        const res = await fetch(`${MIDDLEWARE_URL}/api/auth/login`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password }),
        });

        const data = await res.json();

        if (data.success && data.token) {
          setCookie(COOKIE_NAME, data.token, COOKIE_MAX_AGE);
          localStorage.removeItem('ks_verified_until');
          const redirect = new URLSearchParams(window.location.search).get('redirect') || '/';
          window.location.replace(redirect);
          return;
        }

        const code = data.code || '';
        if (code === 'geo_blocked') {
          showError(MSG_REGION);
        } else if (code === 'upstream_unreachable') {
          showError(MSG_SERVER);
        } else {
          showError(MSG_INVALID);
        }
      } catch {
        showError(MSG_NETWORK);
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = LABEL_SUBMIT;
      }
    });

    (function checkExistingSession() {
      const match = document.cookie.split(';').find((c) => c.trim().startsWith('ks_session='));
      if (!match) return;
      const token = decodeURIComponent(match.split('=')[1] || '');
      if (!token) return;
      const redirect = new URLSearchParams(window.location.search).get('redirect') || '/';
      window.location.replace(redirect);
    })();
  </script>
</body>
</html>
